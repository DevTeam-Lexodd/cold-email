# ─── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Database & Cache ──────────────────────────────────────
# Replace with your paid MongoDB Atlas/self-hosted cluster URI
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cold_email
REDIS_HOST=172.17.0.1
REDIS_PORT=6379

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# ─── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Instantly.ai ──────────────────────────────────────────
INSTANTLY_API_KEY=
INSTANTLY_CAMPAIGN_ID=
INSTANTLY_DEFAULT_CAMPAIGN_ID=

# ─── Microsoft Graph (Outlook) — optional ──────────────────
OWNER_EMAIL=
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_USER_ID=
