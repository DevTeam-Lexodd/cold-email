# ─── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Database & Cache ──────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/cold_email
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# ─── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Instantly.ai ──────────────────────────────────────────
INSTANTLY_API_KEY=
INSTANTLY_CAMPAIGN_ID=
INSTANTLY_DEFAULT_CAMPAIGN_ID=

# ─── Microsoft Graph (Outlook) — optional ──────────────────
OWNER_EMAIL=
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_USER_ID=